// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  department  String
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  attendanceRecords AttendanceRecord[]
  threads          Thread[]          @relation("ThreadAuthor")
  messages         Message[]
  incidents        Incident[]        @relation("IncidentReporter")
  vacationRequests VacationRequest[]
  workSchedules    WorkScheduleEntry[]
  approvedVacations VacationRequest[] @relation("VacationApprover")

  @@map("users")
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  shift     Shift
  clockIn   DateTime
  clockOut  DateTime?
  breakStart DateTime?
  breakEnd  DateTime?
  status    AttendanceStatus
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendance_records")
}

model Thread {
  id           String    @id @default(cuid())
  title        String
  department   String
  shift        Shift?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messageCount Int       @default(0)

  // Relations
  author   User      @relation("ThreadAuthor", fields: [createdBy], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("threads")
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  author    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [author], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Incident {
  id          String        @id @default(cuid())
  title       String
  description String
  severity    Severity
  status      IncidentStatus
  shift       Shift
  department  String
  reportedBy  String
  reportedAt  DateTime      @default(now())
  resolvedAt  DateTime?
  photos      String[]      @default([])
  comments    Json?         // Store comments as JSON for flexibility
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  reporter User @relation("IncidentReporter", fields: [reportedBy], references: [id], onDelete: Cascade)

  @@map("incidents")
}

model VacationRequest {
  id               String           @id @default(cuid())
  userId           String
  startDate        DateTime         @db.Date
  endDate          DateTime         @db.Date
  type             VacationType
  reason           String
  status           VacationStatus   @default(PENDING)
  requestedAt      DateTime         @default(now())
  approvedBy       String?
  approvedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver  User? @relation("VacationApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@map("vacation_requests")
}

model WorkScheduleEntry {
  id         String           @id @default(cuid())
  userId     String
  date       DateTime         @db.Date
  shift      Shift
  startTime  String           // Store as string for flexibility (e.g., "09:00")
  endTime    String           // Store as string for flexibility (e.g., "17:00")
  department String
  status     ScheduleStatus   @default(SCHEDULED)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("work_schedule_entries")
}

// Enums
enum Role {
  ADMIN
  MANAGER
  USER
}

enum Shift {
  SHIFT_1  // 1勤
  SHIFT_2  // 2勤
  SHIFT_3  // 3勤
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EARLY_LEAVE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum VacationType {
  PAID_LEAVE
  SICK_LEAVE
  PERSONAL_LEAVE
  COMPENSATORY_LEAVE
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
}
